{
  "name": "llm-wiki-web",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "description": "Local wiki preview + audit feedback server for the llm-wiki skill.",
  "scripts": {
    "build": "node build-client.mjs",
    "prestart": "npm run build",
    "start": "tsx --env-file-if-exists ../.env server/index.ts",
    "dev": "tsx watch --env-file-if-exists ../.env server/index.ts",
    "test": "tsx --test server/**/*.test.ts"
  },
  "dependencies": {
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "audit-shared": "file:../audit-shared",
    "class-variance-authority": "^0.7.1",
    "cobe": "^2.0.1",
    "d3-drag": "^3.0.0",
    "d3-force": "^3.0.0",
    "d3-selection": "^3.0.0",
    "d3-zoom": "^3.0.0",
    "express": "^4.19.2",
    "framer-motion": "^12.38.0",
    "gsap": "^3.15.0",
    "js-yaml": "^4.1.0",
    "katex": "^0.16.10",
    "lucide-react": "^1.8.0",
    "markdown-it": "^14.1.0",
    "markdown-it-anchor": "^9.0.1",
    "markdown-it-attrs": "^4.2.0",
    "markdown-it-texmath": "^1.0.0",
    "mermaid": "^10.9.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
