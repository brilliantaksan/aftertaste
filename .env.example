# Aftertaste local configuration
#
# Copy this file to `.env` at the repo root when you want optional provider-backed
# analysis. The app also runs without this file; it will use local heuristics and
# file-backed vault behavior.

# Optional: OpenAI-compatible text generation and transcription.
# OPENAI_API_KEY=
# OPENAI_MODEL=
# OPENAI_BASE_URL=https://api.openai.com/v1
# AFTERTASTE_OPENAI_API_KEY=
# AFTERTASTE_OPENAI_MODEL=
# AFTERTASTE_OPENAI_BASE_URL=https://api.openai.com/v1
# AFTERTASTE_OPENAI_TRANSCRIPTION_MODEL=whisper-1

# Optional: AssemblyAI transcription instead of OpenAI transcription.
# AFTERTASTE_TRANSCRIPTION_PROVIDER=assemblyai
# AFTERTASTE_ASSEMBLYAI_API_KEY=
# AFTERTASTE_ASSEMBLYAI_BASE_URL=https://api.assemblyai.com/v2
# AFTERTASTE_ASSEMBLYAI_TRANSCRIPTION_MODEL=

# Optional: Gemini media analysis.
# AFTERTASTE_GEMINI_API_KEY=
# AFTERTASTE_GEMINI_MODEL=gemini-1.5-flash
# AFTERTASTE_GEMINI_BASE_URL=https://generativelanguage.googleapis.com

# Optional: private cobalt instance for fetching source media bytes.
# AFTERTASTE_COBALT_API_URL=http://127.0.0.1:9000
# AFTERTASTE_COBALT_API_KEY=
# AFTERTASTE_COBALT_BEARER_TOKEN=
# AFTERTASTE_COBALT_TIMEOUT_MS=30000
